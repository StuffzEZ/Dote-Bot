# --- Required ---
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-application-id-here

# n8n webhook URL that will receive transcript batches (POST, JSON body)
N8N_WEBHOOK_URL=http://n8n:5678/webhook/meeting-transcript

# --- Optional ---

# Comma-separated guild IDs for instant slash command registration during dev.
# Leave empty to register globally (takes up to ~1hr to propagate to all servers).
DISCORD_GUILD_IDS=

# Whisper model size: tiny, base, small, medium, large-v3
# Bigger = more accurate but slower/more RAM. "base" is a good lightweight default.
WHISPER_MODEL=base

# Force a language code (e.g. "en") to skip auto-detection and speed things up.
# Leave empty to auto-detect.
WHISPER_LANGUAGE=

# How long (ms) a user must be silent before their utterance is considered finished
# and sent off for transcription.
SILENCE_FLUSH_MS=1200

# Utterances shorter than this (ms) are discarded (filters mic pops, coughs, etc).
MIN_UTTERANCE_MS=400

# How often (ms) to batch-send accumulated transcript segments to n8n.
# Set to 0 to send each segment immediately as it's transcribed.
BATCH_INTERVAL_MS=30000

# If the voice channel has no human members for this long (ms), the bot auto-leaves.
AUTO_LEAVE_EMPTY_MS=10000

# debug | info | warn | error
LOG_LEVEL=info
